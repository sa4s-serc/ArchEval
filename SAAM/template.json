{
  "SAAM_Evaluation_Extract": {
    "metadata": {
      "paper_id": "<Unique identifier>",
      "paper_title": "<Full paper title>",
      "authors": ["<Author 1>", "<Author 2>"],
      "year": "<YYYY>",
      "venue": "<Conference/Journal>",
      "doi_or_url": "<Reference link>",
      "extraction_date": "<YYYY-MM-DD>"
    },

    "evaluation_inputs": {
      "system_context": {
        "system_name": "<System Name>",
        "domain": "<Application domain>",
        "system_description": "<High-level purpose and scope>",
        "system_maturity": "Prototype | Development | Production",
        "business_goals": "<If stated>"
      },

      "evaluation_setup": {
        "evaluation_goal": "<Why SAAM was applied>",
        "evaluation_type": "Single Architecture | Architecture Comparison",
        "architectures_evaluated": "<Number>"
      },

      "participants": [
        {
          "role": "Architect | Developer | Maintainer | Stakeholder",
          "count": "<Numeric if available>"
        }
      ],

      "architecture_description": {
        "documentation_level": "High | Medium | Low",
        "architecture_styles": [
          "<If explicitly stated> | Implicit / Not specified | Layered | Client-Server | Component-Based | Other"
        ],
        "architectures": [
          {
            "architecture_id": "A-01",
            "name": "<Label>",
            "description": "<Textual description>",
            "key_components": [
              {
                "component_id": "C-01",
                "component_name": "<Name>",
                "responsibilities": "<Brief description>"
              }
            ],
            "assumptions": ["<If any>"]
          }
        ]
      },

      "scenario_elicitation": {
        "elicitation_method": "Workshop | Interviews | Expert Judgment",
        "scenario_sources": [
          "Stakeholders | Change Requests | Future Needs"
        ],
        "scenario_types": [
          "Use Case",
          "Change (Growth)",
          "Change (Exploratory)"
        ]
      },

      "evaluation_focus": {
        "primary_quality_attribute": "Modifiability",
        "secondary_quality_attributes": [
          "Performance | Reliability | Security | Usability"
        ]
      },

      "scenario_handling": {
        "classification_scheme": "Direct vs Indirect",
        "prioritization_method": "Voting | Ranking | None"
      }
    },

    "ground_truth_outputs": {
      "scenarios": [
        {
          "scenario_id": "S-01",
          "scenario_text": "<Scenario description>",
          "scenario_type": "Use Case | Growth | Exploratory",
          "stakeholder": "<If stated>",
          "priority": "High | Medium | Low"
        }
      ],

      "scenario_classification": [
        {
          "scenario_id": "S-01",
          "classification": "Direct | Indirect",
          "rationale": "<Why>"
        }
      ],

      "scenario_evaluations": [
        {
          "scenario_id": "S-02",
          "architecture_id": "A-01",
          "affected_components": ["C-02", "C-04"],
          "change_description": "<What must change>",
          "change_extent": "Localized | Moderate | Widespread",
          "estimated_effort": "Low | Medium | High",
          "issues_identified": [
            "<Coupling, missing abstraction, ripple effects>"
          ]
        }
      ],

      "scenario_interactions": [
        {
          "interaction_id": "INT-01",
          "interacting_scenarios": ["S-02", "S-05"],
          "shared_components": ["C-03"],
          "interaction_effect": "Negative | Neutral | Positive",
          "modularity_implication": "<Narrative explanation>"
        }
      ],

      "overall_results": {
        "architectural_strengths": ["<Observed strength>"],
        "architectural_weaknesses": ["<Observed weakness>"],
        "modifiability_assessment": "Excellent | Good | Fair | Poor"
      },

      "architecture_comparison": [
        {
          "architecture_id": "A-01",
          "rank": 1,
          "rationale": "<Why it ranked this way>"
        }
      ],

      "recommendations": [
        "<Architectural improvement suggested>"
      ]
    },

    "extraction_metadata": {
      "completeness": "Complete | Partial | Minimal",
      "missing_information": [
        "<Information not reported in paper>"
      ],
      "inference_notes": [
        "<What was inferred by extractor>"
      ]
    }
  }
}
