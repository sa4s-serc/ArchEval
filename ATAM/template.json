{
  "ATAM_Evaluation": {
    "metadata": {
      "system_name": "<System Name>",
      "date": "<YYYY-MM-DD>",
      "ref": "<link>",
      "evaluator_organization": "<Organization Name>",
      "phase_1_attendees": ["<Role/Title>", "<Role/Title>"],
      "phase_2_attendees": ["<Role/Title>", "<Role/Title>"]
    },
    "evaluation_inputs": {
      "system_description": "<A high-level summary of the system's purpose, scope, and key technical/operational context>",
      "phase_1_discovery": {
        "initial_documentation_status": "<Description of the state of documentation at the start (e.g., vague, high-level only)>",
        "evaluator_inquiry_questions": [
          "<Question 1 asked to bridge documentation gaps>",
          "<Question 2 asked to bridge documentation gaps>"
        ]
      },
      "phase_2_architectural_context": {
        "hardware_view_description": [
          "<Statement describing hardware/topology constraint>",
          "<Statement describing hardware/topology constraint>"
        ],
        "runtime_constraints": [
          "<Constraint 1 (e.g., bandwidth limit)>",
          "<Constraint 2 (e.g., max concurrent users)>"
        ]
      },
      "quantitative_model_parameters": {
        "<Parameter Name (e.g., network_bandwidth)>": "<Value>",
        "<Parameter Group (e.g., message_sizes)>": {
          "<Specific Item 1>": "<Value>",
          "<Specific Item 2>": "<Value>"
        },
        "<Parameter Name (e.g., periodic_update_volume)>": "<Value>"
      },
      "investigative_prompts": {
        "style_probes": {
          "target_style": "<Name of Architectural Style being probed>",
          "questions": [
            "<Attribute-specific question 1>",
            "<Attribute-specific question 2>"
          ]
        }
      },
      "raw_candidate_scenarios": [
        {
          "id": "<RS-XX>",
          "description": "<Raw scenario description before prioritization>"
        },
        {
          "id": "<RS-XX>",
          "description": "<Raw scenario description before prioritization>"
        }
      ],
      "business_context": {
        "business_goals": ["<Goal 1>", "<Goal 2>", "<Goal 3>"],
        "technical_constraints": ["<Constraint 1>", "<Constraint 2>"],
        "architectural_drivers": [
          "<Quality Attribute 1>",
          "<Quality Attribute 2>",
          "<Quality Attribute 3>"
        ]
      }
    },
    "ground_truth_outputs": {
      "utility_tree": {
        "root": "Utility",
        "quality_attribute_nodes": [
          {
            "attribute_name": "<Quality Attribute Name (e.g., Performance)>",
            "children": [
              {
                "refinement": "<Specific Attribute Refinement (e.g., Response time < 1s)>",
                "scenario_id": "<ID (e.g., P1)>",
                "scenario_description": "<Description of the scenario>",
                "priority_tuple": {
                  "importance": "<High/Medium/Low>",
                  "difficulty": "<High/Medium/Low>"
                }
              },
              {
                "refinement": "<Specific Attribute Refinement>",
                "scenario_id": "<ID>",
                "scenario_description": "<Description>"
              }
            ]
          }
        ]
      },
      "architectural_approaches": [
        {
          "approach_name": "<Name of Pattern or Style>",
          "description": "<Brief description of how the pattern is applied>",
          "addressed_attributes": [
            {
              "quality_attribute": "<Attribute Name>",
              "rationale": "<Why this approach helps this attribute>"
            }
          ]
        }
      ],
      "analysis_records": [
        {
          "scenario_reference": {
            "id": "<Scenario ID matching Utility Tree or Brainstorming>",
            "text": "<Full text of the scenario being analyzed>",
            "type": "<Use Case | Growth | Exploratory>"
          },
          "quality_attribute": "<Primary Attribute being analyzed>",
          "environment": "<System state (e.g., Normal operations, Overload)>",
          "stimulus": "<Triggering event>",
          "response_measure": "<Measurable goal (e.g., Latency < 100ms)>",
          "architectural_decisions": ["<Key decision 1>", "<Key decision 2>"],
          "reasoning": "<Analysis logic connecting decisions to the response measure>",
          "findings": {
            "risks": [
              {
                "id": "<R-XX>",
                "description": "<Description of the risk>",
                "rationale": "<Why is this a risk?>"
              }
            ],
            "non_risks": [
              {
                "id": "<NR-XX>",
                "description": "<Description of the non-risk>",
                "rationale": "<Why is this safe?>"
              }
            ],
            "sensitivity_points": [
              {
                "id": "<S-XX>",
                "parameter": "<Architectural parameter (e.g., buffer size)>",
                "correlated_attribute": "<Affected attribute>"
              }
            ],
            "tradeoff_points": [
              {
                "id": "<T-XX>",
                "parameter": "<Architectural parameter>",
                "conflicting_attributes": [
                  "<Attribute 1 (positive effect)>",
                  "<Attribute 2 (negative effect)>"
                ]
              }
            ]
          }
        }
      ],
      "scenarios": [
        {
          "scenario_text": "<Full text of the prioritized scenario>",
          "primary_quality_attribute": ["<Attribute 1>", "<Attribute 2>"]
        }
      ]
    }
  }
}
